# Supabase — see docs/02-TECH-STACK.md for the canonical names (ADR-015).
# These exact variable names are read by the codebase. Do not invent variants.

# Project URL, e.g. https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — safe for the browser. Starts with sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — server-only. Starts with sb_secret_...
# NEVER prefix this with NEXT_PUBLIC_, never import it in a client component.
SUPABASE_SECRET_KEY=

# Postgres connection string for Drizzle migrations and the server-side DB client.
# Use the **transaction pooler** URL from Supabase → Project Settings →
# Database → Connection string → "Transaction" tab. The direct connection
# (db.<ref>.supabase.co:5432) is IPv6-only and unreachable from Vercel.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ----------------------------------------------------------------------------
# Email worker (docs/10). Optional — leave blank to disable email digests.
# ----------------------------------------------------------------------------

# Resend API key for sending digests. Get one free at https://resend.com
# (100 emails/day on free tier, no card).
RESEND_API_KEY=

# The "From" header for digest emails. Must be a domain you've verified in
# Resend, or use "onboarding@resend.dev" while testing.
# Format: "Cedi vs Stefi <noreply@yourdomain.com>"
RESEND_FROM=

# Shared secret the Vercel cron job sends in the Authorization header so
# random callers can't trigger the worker. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Public site URL used in email link CTAs. Falls back to the request origin
# if unset; set explicitly for production so links work from cron context.
# Example: https://couple-challenges-amber.vercel.app
NEXT_PUBLIC_SITE_URL=

