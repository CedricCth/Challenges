# Supabase — see docs/02-TECH-STACK.md for the canonical names (ADR-015).
# These exact variable names are read by the codebase. Do not invent variants.

# Project URL, e.g. https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — safe for the browser. Starts with sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — server-only. Starts with sb_secret_...
# NEVER prefix this with NEXT_PUBLIC_, never import it in a client component.
SUPABASE_SECRET_KEY=

# Postgres connection string for Drizzle migrations and the server-side DB client.
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
